
model User {
  id         String       @id @default(uuid()) @db.Char(36)
  user_name  String       @unique
  email      String
  password   String
  role       Role
  tipo       Funcionario? @relation("UserFuncionario")
  created_at DateTime     @default(now())

  @@map("users")
}

model Aluno {
  id                    Int           @id @default(autoincrement())
  nome                  String
  sexo                  Sexo
  data_nascimento       DateTime
  telefone              String?
  telefone_responsavel  String
  rota                  String
  turma                 String
  turno                 Periodo
  bilhete_identificacao String
  contrato              String
  escola_id             Int
  moradas               AlunoMorada[]
  pagamentos            Pagamento[]
  escola                Escola        @relation(fields: [escola_id], references: [id])
  created_at            DateTime      @default(now())

  @@map("alunos")
}

model Funcionario {
  id                      Int                      @id @default(autoincrement())
  nome                    String
  sexo                    Sexo
  data_nascimento         DateTime
  telefone                String
  cargo                   Cargo
  certificado             String
  carta_conducao          String?                  @unique
  salario                 Decimal
  documento_identificacao String
  user_id                 String?                  @unique
  user                    User?                    @relation("UserFuncionario", fields: [user_id], references: [id])
  moradas                 FuncionarioMorada[]
  veiculo_atribuido       FuncionariosToVeiculos?
  created_at              DateTime                 @default(now())

  @@map("funcionarios")
}

model Proprietario {
  id                    Int                  @id @default(autoincrement())
  nome                  String
  sexo                  Sexo
  data_nascimento       DateTime
  telefone              String
  email                 String
  coordenadas_bancarias String
  moradas               ProprietarioMorada[]
  veiculos              Veiculo[]
  created_at            DateTime             @default(now())

  @@map("proprietarios")
}

model Escola {
  id          Int        @id @default(autoincrement())
  nome_escola String
  tipo        TipoEscola
  telefone    String
  localizacao String
  alunos      Aluno[]
  created_at  DateTime   @default(now())

  @@map("escolas")
}

model Morada {
  id            Int                  @id @default(autoincrement())
  municipio     String
  bairro        String
  rua           String
  numero        Int?
  tipo          TipoMorada
  alunos        AlunoMorada[]
  funcionarios  FuncionarioMorada[]
  proprietarios ProprietarioMorada[]

  @@map("moradas")
}

model Veiculo {
  id                    Int                      @id @default(autoincrement())
  marca                 String
  modelo                String
  placa                 String
  tipo                  Tipo
  capacidade            Int
  status                StatusVeiculo
  posse                 PosseVeiculo
  proprietario_id       Int?
  proprietario          Proprietario?            @relation(fields: [proprietario_id], references: [id])
  funcionario_atribuido FuncionariosToVeiculos[]
  created_at            DateTime                 @default(now())

  @@map("veiculos")
}

model Pagamento {
  id                Int             @id @default(autoincrement())
  aluno_id          Int
  aluno             Aluno           @relation(fields: [aluno_id], references: [id])
  referencia        DateTime
  valor_base        Decimal
  multa_aplicada    Decimal?
  valor_total       Decimal
  metodo_pagamento  MeioPagamento
  numero_referencia Int
  comprovante       String
  observacao        String?
  status            StatusPagamento
  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now())

  @@unique([aluno_id, referencia])
  @@map("pagamentos")
}